{
  "name": "skynow-premier-travel-backend",
  "version": "1.0.0",
  "description": "Backend services for SkyNow Premier Travel",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --loader ts-node/esm src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "dotenv -e .env -- prisma db push",
    "prisma:seed": "node --env-file=.env --loader ts-node/esm prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@neondatabase/serverless": "^0.9.4",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-fileupload": "^1.5.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.15.0",
    "puppeteer": "^22.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.5.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/pdfkit": "^0.13.4",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
